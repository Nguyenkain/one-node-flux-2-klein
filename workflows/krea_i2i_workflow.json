{
  "KREAI2I:MODEL": {
    "inputs": {
      "unet_name": "krea2TurboFP8_krea2TURBO.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader",
    "_meta": {
      "title": "Load Krea UNet"
    }
  },
  "KREAI2I:CLIP": {
    "inputs": {
      "clip_name": "qwen3vl_4b_bf16.safetensors",
      "type": "krea2",
      "device": "default"
    },
    "class_type": "CLIPLoader",
    "_meta": {
      "title": "Load Krea CLIP"
    }
  },
  "KREAI2I:VAE": {
    "inputs": {
      "vae_name": "qwen_image_vae.safetensors"
    },
    "class_type": "VAELoader",
    "_meta": {
      "title": "Load Krea VAE"
    }
  },
  "KREAI2I:LOAD": {
    "inputs": {
      "image": "example.png",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "Load Input Image"
    }
  },
  "KREAI2I:VAEENC": {
    "inputs": {
      "pixels": [
        "KREAI2I:LOAD",
        0
      ],
      "vae": [
        "KREAI2I:VAE",
        0
      ]
    },
    "class_type": "VAEEncode",
    "_meta": {
      "title": "Krea VAE Encode"
    }
  },
  "KREAI2I:POS": {
    "inputs": {
      "text": "",
      "clip": [
        "KREAI2I:CLIP",
        0
      ]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Krea I2I Positive Prompt"
    }
  },
  "KREAI2I:NEGBASE": {
    "inputs": {
      "text": "",
      "clip": [
        "KREAI2I:CLIP",
        0
      ]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Krea I2I Negative Base"
    }
  },
  "KREAI2I:NEG": {
    "inputs": {
      "conditioning": [
        "KREAI2I:NEGBASE",
        0
      ]
    },
    "class_type": "ConditioningZeroOut",
    "_meta": {
      "title": "Krea I2I Negative Zero"
    }
  },
  "KREAI2I:KS": {
    "inputs": {
      "seed": 0,
      "steps": 8,
      "cfg": 1,
      "sampler_name": "er_sde",
      "scheduler": "simple",
      "denoise": 0.75,
      "model": [
        "KREAI2I:MODEL",
        0
      ],
      "positive": [
        "KREAI2I:POS",
        0
      ],
      "negative": [
        "KREAI2I:NEG",
        0
      ],
      "latent_image": [
        "KREAI2I:VAEENC",
        0
      ]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "Krea I2I KSampler"
    }
  },
  "KREAI2I:DECODE": {
    "inputs": {
      "samples": [
        "KREAI2I:KS",
        0
      ],
      "vae": [
        "KREAI2I:VAE",
        0
      ]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "Krea I2I Decode"
    }
  },
  "KREAI2I:SAVE": {
    "inputs": {
      "filename_prefix": "one-node-flux-2-klein/krea",
      "images": [
        "KREAI2I:DECODE",
        0
      ]
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "Save Image"
    }
  }
}